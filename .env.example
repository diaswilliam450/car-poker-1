# Poker44 miner configuration (example)
# Copy to `.env` and adjust:  cp .env.example .env
# Loaded by neurons/miner.py via python-dotenv.
# NOTE: Bittensor wallet / netuid / axon / subtensor are passed as CLI flags
# (see the run command at the bottom), NOT through this file.

# ─── Model artifact ───────────────────────────────────────────────────────────
# Path to the trained model_v2 artifact: a joblib bundle of
# {LightGBM model, cliff-aware calibrator, feature_names}. Whole-chunk,
# order-invariant scoring — no windowing knobs needed.
P44_MODEL_PATH=detection_model/artifacts/p44_v2_lgbm_canon.joblib

# Ignored when the artifact embeds a calibrator (the 0.5 boundary is already
# placed under the FPR cliff). Only used by the legacy no-calibrator fallback.
P44_PREDICTION_THRESHOLD=0.5

# ─── Top-K bot cap (FPR protection; default OFF) ──────────────────────────────
# When enabled, only the K highest-scoring chunks in a synapse are pushed above
# the 0.5 boundary (classified bot); the rest are forced below it. Ranking (and
# therefore the validator's AP term) is preserved exactly — this only moves the
# recall/FPR trade at the boundary. Useful when serving an out-of-distribution
# feed where absolute scores collapse but the ranking still holds.
#
# WARNING: this is a bet on the ranking. If the feed is mostly human, forcing
# bots manufactures false positives and can trip the 0.10 FPR cliff (reward 0).
# Prefer a small fraction (0.10–0.15) over an aggressive one.
#
# P44_TOP_K       = absolute count of top chunks to flag as bot (0 = off).
# P44_TOP_K_FRAC  = batch-relative fraction 0..1, used only when P44_TOP_K is 0
#                   (more robust to varying synapse sizes).
P44_TOP_K=0
P44_TOP_K_FRAC=0

# ─── Transparency manifest (optional; sane defaults exist) ────────────────────
P44_MANIFEST_MODEL_NAME=p44-v2-lgbm-tabular
P44_MANIFEST_MODEL_VERSION=2.1.0
P44_MANIFEST_FRAMEWORK=lightgbm-tabular-features
P44_MANIFEST_LICENSE=MIT
# repo_url + repo_commit are AUTO-DERIVED from `git` at startup (origin remote +
# HEAD), so the manifest is `transparent`-compliant out of the box when run from
# a git checkout. Only set these to override the detected values (e.g. running
# from a non-git deploy, or to pin a published commit).
P44_MANIFEST_REPO_URL=
P44_MANIFEST_REPO_COMMIT=
P44_MANIFEST_ARTIFACT_URL=
P44_MANIFEST_MODEL_CARD_URL=
# Leave blank to auto-compute the sha256 of P44_MODEL_PATH at startup.
P44_MANIFEST_ARTIFACT_SHA256=
POKER44_MODEL_ARTIFACT_SHA256=

# ─── Run command (wallet/netuid/axon are CLI flags, not env) ──────────────────
# python neurons/miner.py \
#   --netuid <NETUID> \
#   --subtensor.network finney \
#   --wallet.name <coldkey> --wallet.hotkey <hotkey> \
#   --axon.port <PORT> \
#   --logging.debug
